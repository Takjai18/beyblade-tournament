# Server — local Homebrew PostgreSQL (trust auth, OS user)
DATABASE_URL="postgresql://mingtakyau@localhost:5432/beyblade_tournament?schema=public"
# Docker alternative: postgresql://postgres:postgres@localhost:5432/beyblade_tournament?schema=public
JWT_SECRET="change-me-in-production"
PORT=3000
CORS_ORIGIN="http://localhost:5173"
HOST=0.0.0.0

# Phase 3 — Gemini Vision (server-side only; never expose in frontend)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Web (apps/web/.env) — leave empty to use Vite proxy in dev
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

